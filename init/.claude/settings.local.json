      "WebFetch(domain:opencode.ai)",
      "Bash(mkdir -p:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git tag:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(npm view:*)",
      "Bash(npm whoami:*)",
      "Bash(npm run validate)",
      "Bash(npm run lint:workflows)",
      "Bash(python design-search.py:*)",
      "Bash(python /c/GENERATOR/design-search.py:*)",
      "Bash(pwsh -File scripts/sync-commands.ps1)",
