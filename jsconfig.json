{
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "moduleResolution": "node",
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "App.jsx"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "temp-build"
  ]
}
